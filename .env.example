# ============================================
# RecallFlow Environment Variables
# ============================================

# Backend
APP_NAME=RecallFlow
APP_VERSION=1.0.0
DEBUG=True

# Database
# Local development (SQLite - no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./recallflow.db
# Production (PostgreSQL via Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/recallflow

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (comma-separated frontend URLs)
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Email (placeholder — for future email notification support)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ============================================
# Frontend (.env.local in frontend/)
# ============================================
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_APP_NAME=RecallFlow
